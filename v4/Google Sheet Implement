The code is all done. Now here's exactly what to do in Google Sheets to connect it:

Step 1 — Open your Google Sheet, then go to Extensions → Apps Script

Step 2 — Delete anything in the editor and paste this code:

function doGet(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  const p = e.parameter;
  sheet.appendRow([
    p.date,
    p.time,
    p.name,
    p.phone,
    p.furniture,
    p.message
  ]);
  return ContentService
    .createTextOutput(JSON.stringify({ status: 'ok' }))
    .setMimeType(ContentService.MimeType.JSON);
}
